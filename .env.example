# AI Novel 环境变量配置
# 复制此文件为 .env 并按需修改

# 后端服务
AI_NOVEL_PORT=8899
AI_NOVEL_HOST=0.0.0.0
AI_NOVEL_DEBUG=false

# 数据存储目录（SQLite 数据库 + 小说文件）
AI_NOVEL_DATA_DIR=data

# CORS 允许的来源（逗号分隔，开发时前端地址）
AI_NOVEL_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM 请求超时（秒）
AI_NOVEL_LLM_TIMEOUT_SECONDS=600

# API Key 加密密钥（可选，用于加密存储 Provider API Key）
# AI_NOVEL_API_KEY_ENCRYPTION_KEY=

# 改写窗口模式
AI_NOVEL_REWRITE_WINDOW_MODE_ENABLED=true
AI_NOVEL_REWRITE_WINDOW_MODE_GUARDRAIL_ENABLED=true
AI_NOVEL_REWRITE_WINDOW_MODE_AUDIT_ENABLED=true
